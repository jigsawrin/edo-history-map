{
  "name": "edo-history-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "いま・むかし地図 - 現代地図と江戸後期の歴史GISデータを重ねて表示する静的Webアプリ",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "data:convert": "node scripts/convert-owariya.mjs",
    "data:convert:machiya": "node scripts/convert-machiya-areas.mjs",
    "data:convert:coastline": "node scripts/convert-historical-coastline.mjs",
    "audit:prepublish": "node scripts/prepublish-audit.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^26.1.1",
    "eslint": "^9.20.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
