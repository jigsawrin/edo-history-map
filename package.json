{
  "name": "edo-history-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "いま・むかし地図 - 東京・江戸と京都の歴史データを地域ごとに表示する静的Webアプリ",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && npm run build:static-places && npm run build:static-themes && npm run build:static-timeline && npm run audit:static-links",
    "build:static-places": "node scripts/build-static-place-pages.mjs",
    "build:static-themes": "node scripts/build-static-theme-pages.mjs",
    "build:static-timeline": "node scripts/build-static-timeline-pages.mjs",
    "audit:static-links": "node scripts/audit-static-place-links.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "data:convert": "node scripts/convert-owariya.mjs",
    "data:convert:machiya": "node scripts/convert-machiya-areas.mjs",
    "data:convert:coastline": "node scripts/convert-historical-coastline.mjs",
    "data:build:kyoto": "node scripts/build-kyoto-bakumatsu-places.mjs",
    "data:build:shiga": "node scripts/build-shiga-sengoku-places.mjs",
    "audit:prepublish": "node scripts/prepublish-audit.mjs",
    "audit:historical-rasters": "node scripts/audit-historical-rasters.mjs",
    "audit:historical-raster-candidates": "node scripts/historical-raster-candidates.mjs",
    "verify:historical-raster-package": "node scripts/historical-raster-package.mjs",
    "analyze:historical-raster-image": "node scripts/inspect-jpeg.mjs data-raw/historical-rasters/taito-2017-chi-009/2017_chi_009_002-canvas-002.jpg"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^26.1.1",
    "eslint": "^9.20.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
